<Window x:Class="AIHomeDashboard.Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Home Dashboard Installer"
        Width="620"
        Height="500"
        MinWidth="560"
        MinHeight="460"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Grid Background="#f8fafc">
        <Border Margin="24"
                Padding="22"
                Background="White"
                BorderBrush="#cbd5e1"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="AI Home Dashboard"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="#0f172a" />
                    <TextBlock Text="Choose how and where to install the dashboard on this machine."
                               Margin="0,6,0,0"
                               FontSize="13"
                               Foreground="#475569" />
                </StackPanel>

                <GroupBox Grid.Row="1"
                          Header="Install scope"
                          Margin="0,22,0,0"
                          Padding="12">
                    <StackPanel>
                        <RadioButton x:Name="CurrentUserRadio"
                                     Content="Install for current user"
                                     IsChecked="True"
                                     Checked="Scope_Changed" />
                        <TextBlock Text="Installs under your user profile and does not require administrator rights."
                                   Margin="22,4,0,10"
                                   Foreground="#64748b"
                                   FontSize="12" />
                        <RadioButton x:Name="AllUsersRadio"
                                     Content="Install for all users"
                                     Checked="Scope_Changed" />
                        <TextBlock Text="Installs under Program Files and requires running this installer as Administrator."
                                   Margin="22,4,0,0"
                                   Foreground="#64748b"
                                   FontSize="12" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="2"
                          Header="Install location"
                          Margin="0,16,0,0"
                          Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="InstallPathTextBox"
                                 MinHeight="34"
                                 VerticalContentAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="Browse..."
                                MinWidth="92"
                                Margin="10,0,0,0"
                                Click="Browse_Click" />
                    </Grid>
                </GroupBox>

                <StackPanel Grid.Row="3"
                            Margin="0,16,0,0">
                    <CheckBox x:Name="StartMenuShortcutCheckBox"
                              Content="Create Start Menu shortcut"
                              IsChecked="True" />
                    <CheckBox x:Name="DesktopShortcutCheckBox"
                              Content="Create desktop shortcut"
                              IsChecked="True"
                              Margin="0,8,0,0" />
                    <CheckBox x:Name="LaunchAfterInstallCheckBox"
                              Content="Launch AI Home Dashboard after install"
                              IsChecked="True"
                              Margin="0,8,0,0" />
                    <TextBlock x:Name="StatusText"
                               Text=""
                               Margin="0,18,0,0"
                               TextWrapping="Wrap"
                               Foreground="#334155" />
                </StackPanel>

                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,18,0,0">
                    <Button Content="Cancel"
                            MinWidth="92"
                            Margin="0,0,10,0"
                            Click="Cancel_Click" />
                    <Button x:Name="InstallButton"
                            Content="Install"
                            MinWidth="110"
                            FontWeight="SemiBold"
                            Click="Install_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
