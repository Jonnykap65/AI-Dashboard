<Window x:Class="AIHomeDashboard.Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Home Dashboard Setup"
        Width="760" Height="520" MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        Background="#F5F7FB" Loaded="Window_Loaded">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#172033" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="64" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="#12213F">
                <Grid Margin="28,30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Width="66" Height="66" HorizontalAlignment="Left" CornerRadius="14" Background="#2563EB">
                        <TextBlock Text="AI" Foreground="White" FontSize="26" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Row="1" Margin="0,24,0,0">
                        <TextBlock Text="AI Home" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                        <TextBlock Text="Dashboard" Foreground="#93C5FD" FontSize="24" FontWeight="SemiBold" />
                        <TextBlock Text="Your local command center for projects, schedules, systems, and knowledge."
                                   Foreground="#CBD5E1" Margin="0,18,0,0" FontSize="13" LineHeight="20" TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock Grid.Row="2" Text="SETUP" Foreground="#64748B" FontSize="11" FontWeight="SemiBold" />
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="42,34,42,26">
                <Grid x:Name="WelcomePage">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Welcome to AI Home Dashboard Setup" FontSize="26" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock Text="This wizard will install AI Home Dashboard on your computer."
                                   Margin="0,16,0,0" FontSize="15" Foreground="#526079" TextWrapping="Wrap" />
                        <TextBlock Text="Close other copies of AI Home Dashboard before continuing. Your existing dashboard data and configuration will be preserved when updating."
                                   Margin="0,24,0,0" FontSize="13" LineHeight="20" Foreground="#64748B" TextWrapping="Wrap" />
                        <Border Margin="0,28,0,0" Padding="14" CornerRadius="6" Background="#EAF2FF">
                            <TextBlock Text="Click Next to review installation options." Foreground="#1E40AF" FontSize="13" />
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid x:Name="OptionsPage" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Installation options" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="Choose who can use the app and where it will be installed."
                                       Margin="0,6,0,22" Foreground="#64748B" FontSize="13" />
                            <TextBlock Text="Install for" FontWeight="SemiBold" FontSize="13" />
                            <RadioButton x:Name="CurrentUserRadio" Content="Only me (recommended)" IsChecked="True"
                                         Margin="0,10,0,0" Checked="Scope_Changed" />
                            <RadioButton x:Name="AllUsersRadio" Content="Anyone who uses this computer"
                                         Margin="0,9,0,0" Checked="Scope_Changed" />
                            <TextBlock Text="Installing for everyone requires administrator permission."
                                       Margin="22,5,0,0" Foreground="#64748B" FontSize="12" />
                            <TextBlock Text="Install location" Margin="0,20,0,8" FontWeight="SemiBold" FontSize="13" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox x:Name="InstallPathTextBox" Height="34" Padding="8,0" VerticalContentAlignment="Center" />
                                <Button Grid.Column="1" Content="Browse..." Margin="10,0,0,0" Click="Browse_Click" />
                            </Grid>
                            <WrapPanel Margin="0,20,0,0">
                                <CheckBox x:Name="StartMenuShortcutCheckBox" Content="Start Menu shortcut" IsChecked="True" Margin="0,0,24,0" />
                                <CheckBox x:Name="DesktopShortcutCheckBox" Content="Desktop shortcut" IsChecked="True" />
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="ProgressPage" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Installing AI Home Dashboard" FontSize="24" FontWeight="SemiBold" />
                        <TextBlock x:Name="ProgressStatusText" Text="Preparing installation..." Margin="0,12,0,22" Foreground="#64748B" />
                        <ProgressBar x:Name="InstallProgressBar" Height="8" Minimum="0" Maximum="100" Value="0" />
                        <TextBlock Text="Please wait while Setup installs the application."
                                   Margin="0,18,0,0" Foreground="#64748B" FontSize="13" />
                    </StackPanel>
                </Grid>

                <Grid x:Name="FinishPage" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Setup complete" FontSize="28" FontWeight="SemiBold" />
                        <TextBlock Text="AI Home Dashboard has been installed successfully."
                                   Margin="0,14,0,0" FontSize="15" Foreground="#526079" />
                        <TextBlock x:Name="InstalledLocationText" Margin="0,10,0,26" FontSize="12" Foreground="#64748B" TextWrapping="Wrap" />
                        <CheckBox x:Name="LaunchAfterInstallCheckBox" Content="Launch AI Home Dashboard" IsChecked="True" FontSize="13" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <Border Grid.Row="1" Background="White" BorderBrush="#D8DEE9" BorderThickness="0,1,0,0">
            <Grid Margin="24,0">
                <TextBlock x:Name="StepText" Text="Step 1 of 2" VerticalAlignment="Center" Foreground="#78859A" FontSize="12" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BackButton" Content="Back" Margin="0,0,10,0" Visibility="Collapsed" Click="Back_Click" />
                    <Button x:Name="CancelButton" Content="Cancel" Margin="0,0,10,0" Click="Cancel_Click" />
                    <Button x:Name="NextButton" Content="Next" Style="{StaticResource PrimaryButton}" Click="Next_Click" />
                    <Button x:Name="InstallButton" Content="Install" Style="{StaticResource PrimaryButton}" Visibility="Collapsed" Click="Install_Click" />
                    <Button x:Name="FinishButton" Content="Finish" Style="{StaticResource PrimaryButton}" Visibility="Collapsed" Click="Finish_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
