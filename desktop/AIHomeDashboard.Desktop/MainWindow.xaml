<Window x:Class="AIHomeDashboard.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="AI Home Dashboard"
        Width="1280"
        Height="860"
        MinWidth="1024"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing"
        Loaded="Window_Loaded">
    <Grid>
        <wv2:WebView2 x:Name="DashboardView" Visibility="Collapsed" />
        <Border x:Name="LoadingPanel" Background="#0f172a">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="AI Home Dashboard"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="Starting local dashboard..."
                           Foreground="#cbd5e1"
                           FontSize="14"
                           Margin="0,12,0,0"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
